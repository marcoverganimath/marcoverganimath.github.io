@article{vergani2024uniformlysemirationalsimplegroups,
         bibtex_show={true},
         abstract={A finite group $G$ is called \emph{uniformly semi-rational} if there exists an integer $r$ such that the generators of every cyclic sugroup $\langle x \rangle$ of $G$ lie in at most two conjugacy classes, namely $x^G$ or $(x^r)^G$. In this paper, we provide a classification of uniformly semi-rational non-abelian simple groups with particular focus on alternating groups. },
          title={Uniformly semi-rational simple groups}, 
          author={Marco Vergani},
          year={2024},
          arxiv={2410.11069},
          primaryClass={math.GR},
          url={https://arxiv.org/abs/2410.11069}, 
          html={https://arxiv.org/html/2410.11069},
          pdf={https://arxiv.org/pdf/2410.11069}
}

@article{delrío2024uniformlysemirationalgroups,
 bibtex_show={true},
      title={Uniformly semi-rational groups}, 
      author={Ángel del Río and Marco Vergani},
      abstract={We introduce and study some families of groups whose irreducible characters take values on quadratic extensions of the rationals. We focus mostly on a generalization of inverse semi-rational groups, which we call uniformly semi-rational groups. Moreover, we associate to every finite group two invariants, called rationality and semi-rationality of the group. They measure respectively how far a group is from being rational and how much uniformly rational it is. We determine the possible values that these invariants may take for finite nilpotent groups. We also classify the fields that can occur as the field generated by the character values of a finite nilpotent group.},
      year={2024},
      arxiv={2411.16563},
      primaryClass={math.GR},
      url={https://arxiv.org/abs/2411.16563}, 
        html={https://arxiv.org/html/2411.16563},
        pdf={https://arxiv.org/pdf/2411.16563}
}





